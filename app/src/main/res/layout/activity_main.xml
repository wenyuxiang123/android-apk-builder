<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#1A1A2E"
    android:gravity="center_horizontal">

    <!-- Logo区域 -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp"/>

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_description"
        android:textSize="16sp"
        android:textColor="#00BCD4"
        android:layout_marginBottom="32dp"/>

    <!-- 状态显示 -->
    <TextView
        android:id="@+id/text_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ready"
        android:textSize="18sp"
        android:textColor="#4CAF50"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- 功能按钮 -->
    <Button
        android:id="@+id/btn_data_collection"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/data_collection"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#2196F3"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_start_aim"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/start_aim_assist"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_accessibility_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/accessibility_settings"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#FF9800"
        android:layout_marginBottom="24dp"/>

    <!-- 权限状态 -->
    <TextView
        android:id="@+id/text_permission_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:background="#2D2D44"
        android:padding="16dp"
        android:layout_marginBottom="24dp"/>

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/usage_instructions"
        android:textSize="12sp"
        android:textColor="#666666"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
