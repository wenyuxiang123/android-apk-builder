<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DeltaAim"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 瞄准辅助系统"
            android:textSize="16sp"
            android:textColor="#00BCD4"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="状态"
            android:textSize="14sp"
            android:textColor="#B0BEC5"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_ready"
            android:textSize="20sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- 自动模式开关 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            android:background="#0F3460"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自动模式"
                android:textSize="14sp"
                android:textColor="#FFFFFF"/>

            <Switch
                android:id="@+id/switch_auto_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="自动模式状态"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/text_auto_mode_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ 已关闭"
                android:textSize="12sp"
                android:textColor="#F44336"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/permission_accessibility"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/text_accessibility_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ 未启用"
                android:textSize="12sp"
                android:textColor="#F44336"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/permission_overlay"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/text_overlay_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ 未授权"
                android:textSize="12sp"
                android:textColor="#F44336"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/permission_screenshot"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/text_screenshot_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✗ 未激活"
                android:textSize="12sp"
                android:textColor="#F44336"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_data_collection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="数据采集"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F3460"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_start_aim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="启动瞄准辅助"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F3460"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_accessibility_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="无障碍服务设置"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0F3460"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="使用说明：\n\n1. 点击「无障碍服务设置」启用 DeltaAim 服务\n\n2. 根据提示授予悬浮窗权限\n\n3. 开启「自动模式」开关\n\n4. 当检测到《三角洲行动》启动时，将自动开启数据采集和瞄准辅助\n\n5. 也可以手动点击按钮控制功能"
            android:textSize="12sp"
            android:textColor="#B0BEC5"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
</ScrollView>
