<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1A1A2E">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="数据采集"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- 状态显示 -->
    <TextView
        android:id="@+id/text_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="准备就绪"
        android:textSize="16sp"
        android:textColor="#00BCD4"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/text_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="已采集: 0 张"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- 间隔设置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="采集间隔"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <Spinner
            android:id="@+id/spinner_interval"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:background="#2D2D44"
            android:popupBackground="#2D2D44"/>

    </LinearLayout>

    <!-- 目标数量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="目标数量 (留空无限)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/edit_count"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:background="#2D2D44"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:hint="数量"
            android:inputType="number"
            android:gravity="center"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- 操作按钮 -->
    <Button
        android:id="@+id/btn_start_capture"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="开始采集"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#4CAF50"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_stop_capture"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="停止采集"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#F44336"
        android:enabled="false"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_single_capture"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="单张截图"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#2196F3"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_open_folder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="打开采集目录"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:background="#FF9800"
        android:layout_marginBottom="24dp"/>

    <!-- 存储路径 -->
    <TextView
        android:id="@+id/text_path"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="存储位置: /storage/emulated/0/Pictures/DeltaAim_Dataset"
        android:textSize="12sp"
        android:textColor="#666666"
        android:gravity="center"/>

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="使用说明:\n1. 点击开始采集，授权屏幕录制\n2. 切换到游戏界面开始采集\n3. 采集完成后可在相册/DeltaAim_Dataset目录查看"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="24dp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
